{
	"name": "pi-copy-clear",
	"version": "1.0.0",
	"description": "Pi extension that binds keyboard shortcuts to editor actions: copy+clear the current prompt, or submit a fixed text payload (e.g. a slash command) to the agent.",
	"keywords": [
		"pi-package"
	],
	"license": "MIT",
	"author": "",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src"
	],
	"scripts": {
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"clipboardy": "^4.0.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typescript": "^5.0.0"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	}
}
